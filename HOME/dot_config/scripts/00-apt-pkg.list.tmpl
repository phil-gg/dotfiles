{{/* Define WSL test variable */ -}}
{{ $wsl := stat "/run/WSL" -}}
{{/* Bash to list all Debian [essential|priority|important] pkgs */ -}}
{{ output "bash" "-c" `\
comm -23 <(aptitude search -F '%p' '~E|~prequired|~pimportant' | sort) \
         <(aptitude search -F '%p' '~E|~prequired|~pimportant' | xargs \
           apt-cache depends | awk '/Depends:|PreDepends:/ {print $NF}' | \
           tr -d '<>' | sort -u)` -}}
